generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Better Auth core models ────────────────────────────────────────────────
// Shape matches what @better-auth/cli generate produces for the Prisma
// adapter (email/password + Google OAuth + session management).

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  memberships Membership[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id         String @id @default(uuid())
  accountId  String
  providerId String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ── Outrun domain models ───────────────────────────────────────────────────
// docs/outrun/12-database-architecture-scalability.md,
// docs/outrun/14-billing-subscriptions-teams-enterprise.md

enum MembershipRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum PlanTier {
  FREE
  STARTER
  GROWTH
  UNLIMITED
}

enum GrowthStage {
  IDEA
  STARTUP
  GROWING
  ESTABLISHED
  AGENCY
  ENTERPRISE
}

// One Organization per business workspace. Fields populated by Business
// Discovery onboarding (docs/outrun/03) are nullable here because they are
// captured in a later build phase, not because they're optional in the
// finished product.
model Organization {
  id          String       @id @default(uuid())
  name        String
  website     String?
  industry    String?
  country     String?
  growthStage GrowthStage?
  brandVoice  String?
  planTier    PlanTier     @default(FREE)

  growthScore Int? // 0-100, set once a Growth Blueprint exists

  // Billing (docs/outrun/14). Set only by verified Paddle webhooks
  // (src/app/api/billing/webhook/route.ts) — never by the client, so plan
  // access can't be forged from the frontend (Article XII).
  paddleCustomerId     String?
  paddleSubscriptionId String?
  subscriptionStatus   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships      Membership[]
  businessProfile  BusinessProfile?
  growthBlueprints GrowthBlueprint[]
  companies        Company[]
  usageEvents      UsageEvent[]
  campaigns        Campaign[]
  events           Event[]
  chatMessages     ChatMessage[]
  seoAnalyses      SeoAnalysis[]
  seoContentPieces SeoContentPiece[]
  invitations      Invitation[]

  @@map("organization")
}

enum UsageEventType {
  COMPANY_SEARCH
  COMPANY_RESEARCH
  OUTREACH_GENERATION
  BLUEPRINT_GENERATION
}

// One row per billable action taken (docs/outrun/14 "USAGE METERS"). Counted
// lifetime-per-workspace against src/lib/billing/usage.ts limits — Free plan
// allotments don't renew monthly, matching the "unlock more with Starter"
// framing in docs/outrun/03, not a "resets next month" model.
model UsageEvent {
  id String @id @default(uuid())

  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           UsageEventType

  createdAt DateTime @default(now())

  @@map("usage_event")
}

// Captured by the Business Discovery onboarding conversation
// (docs/outrun/03). One per Organization; the AI Growth Blueprint reads
// entirely from this plus website analysis — never invents facts beyond it.
model BusinessProfile {
  id String @id @default(uuid())

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  description         String
  idealCustomer       String
  sellingLocations    String[]
  acquisitionChannels String[]
  growthChallenge     String
  avgCustomerValue    Int?
  mainGoal            String
  competitors         String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("business_profile")
}

// One row per generated/regenerated Blueprint — versioned, never overwritten
// (docs/outrun/05 "VERSION HISTORY"). Structured sub-sections are stored as
// JSON because their shape is validated by the Zod schema in
// src/lib/growth-blueprint/schema.ts at generation time, not by Postgres.
model GrowthBlueprint {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  version        Int

  growthScore          Int
  executiveSummary     String
  strengths            Json
  weaknesses           Json
  biggestBottleneck    Json
  opportunities        Json
  growthStrategy       Json
  idealCustomerProfile Json
  roadmap              Json
  scoreCategories      Json
  confidenceNotes      String

  createdAt DateTime @default(now())

  @@unique([organizationId, version])
  @@map("growth_blueprint")
}

// A prospect surfaced by lead search (docs/outrun/06). `source`/`sourceId`
// identify which provider and which of its records this came from, so the
// same real-world business is never duplicated within a workspace
// ("DUPLICATE DETECTION"). fitScore/confidenceScore are set immediately at
// search time by a cheap heuristic (src/lib/prospects/scoring.ts); `research`
// is filled in later, only on demand, by an AI call — expensive analysis is
// never run on results the user hasn't asked about.
model Company {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  source   String
  sourceId String

  name             String
  category         String?
  website          String?
  phone            String?
  formattedAddress String?
  rating           Float?
  reviewCount      Int?

  fitScore        Int?
  confidenceScore Int?
  research        Json?

  isSaved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  outreachMessages OutreachMessage[]

  @@unique([organizationId, source, sourceId])
  @@map("company")
}

// One generated email per company (docs/outrun/07). Standalone messages
// (generated from a single company's research profile) have no campaign;
// batch-generated messages from a Campaign are linked via campaignId.
model OutreachMessage {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  subject          String
  body             String
  openingRationale String

  createdAt DateTime @default(now())

  @@map("outreach_message")
}

enum CampaignStatus {
  DRAFT
  READY
  PAUSED
  COMPLETED
}

// Batches outreach generation across a chosen audience (docs/outrun/07
// Campaign Builder). No send mechanics yet — that needs a separate email
// provider integration (Gmail/SMTP, docs/outrun/11) that hasn't been
// decided. A campaign reaching READY means messages are generated and
// reviewed, not that anything was actually delivered.
model Campaign {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name      String
  objective String
  status    CampaignStatus @default(DRAFT)

  strategyRationale  String?
  strategyConfidence String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages OutreachMessage[]

  @@map("campaign")
}

// Joins a User to an Organization with a role (docs/outrun/14 permissions).
model Membership {
  id   String         @id @default(uuid())
  role MembershipRole @default(OWNER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@map("membership")
}

enum EventType {
  BLUEPRINT_GENERATED
  COMPANY_SEARCHED
  COMPANY_RESEARCHED
  OUTREACH_GENERATED
  CAMPAIGN_CREATED
  SEO_ANALYZED
  SEO_CONTENT_GENERATED
  TEAM_MEMBER_INVITED
  TEAM_MEMBER_JOINED
}

// The Business Brain's growth timeline (docs/outrun/08 "GROWTH MEMORY" /
// "BUSINESS TIMELINE") — a plain event log, not a knowledge graph. Every
// meaningful action across the app writes one row here via
// src/lib/memory/log-event.ts, giving a single searchable history without
// a heavier memory architecture this stage doesn't need yet.
model Event {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type    EventType
  summary String

  createdAt DateTime @default(now())

  @@map("event")
}

enum ChatRole {
  USER
  ASSISTANT
}

// One row per turn in "Ask the CEO" (docs/outrun/10). Kept simple —
// a single ongoing conversation per organization, not multiple named
// threads; the last N turns plus the Business Brain context
// (src/lib/memory/context.ts) is what gets sent to the model each time.
model ChatMessage {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  role    ChatRole
  content String

  createdAt DateTime @default(now())

  @@map("chat_message")
}

// One row per crawl+analysis run (docs/outrun/09), versioned like the
// Growth Blueprint. Only stores what was actually observed in the crawled
// HTML plus AI-derived scores/recommendations from it — no Core Web
// Vitals, backlinks, or rank data, since none of those integrations exist.
model SeoAnalysis {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  version        Int

  healthScore        Int
  executiveSummary   String
  categories         Json
  quickWins          Json
  keywordSuggestions Json
  contentIdeas       Json

  createdAt DateTime @default(now())

  @@unique([organizationId, version])
  @@map("seo_analysis")
}

// One generated content draft (docs/outrun/09 "AI CONTENT GENERATOR") —
// a standalone draft the user copies out to their own CMS; Outrun never
// publishes anything on their behalf (Article XVIII, user control).
model SeoContentPiece {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  targetKeyword   String
  title           String
  metaDescription String
  body            String

  createdAt DateTime @default(now())

  @@map("seo_content_piece")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  CANCELLED
  EXPIRED
}

// Team invitations (docs/outrun/14 "TEAM WORKSPACES" / "INVITATIONS"). Team
// seats aren't gated by plan tier: Growth/Unlimited (the plans the spec
// scopes "Team Collaboration" to) have no Paddle price yet, so — matching
// the same call already made for usage limits in src/lib/billing/usage.ts —
// this ships unlimited to every plan rather than locked behind a plan
// nobody can buy.
model Invitation {
  id String @id @default(uuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  email  String
  role   MembershipRole @default(MEMBER)
  token  String         @unique
  status InvitationStatus @default(PENDING)

  invitedByUserId String
  expiresAt       DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("invitation")
}
