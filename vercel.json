{
  "buildCommand": "npm run db:migrate:deploy && npm run build",
  "crons": [
    {
      "path": "/api/cron/autonomous-send",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/strategic-reviews",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/job-queue",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/webhooks",
      "schedule": "*/5 * * * *"
    }
  ]
}
