# Postgres connection string
DATABASE_URL="postgresql://outrun:outrun_dev_password@localhost:5432/outrun_dev"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Continue with Google button is hidden until these are set)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID / Azure AD OAuth (Continue with Microsoft button is
# hidden until CLIENT_ID/CLIENT_SECRET are set). TENANT_ID can be a GUID,
# "common", "organizations", or "consumers" — defaults to "common".
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# Outbound email (verification / password reset, and docs/outrun/07 outreach
# sending to prospects). Leave unset in development: auth emails log to the
# server console instead, and the Send button on outreach/campaigns stays
# honestly disabled with an explanatory note rather than faking a send.
RESEND_API_KEY=""
EMAIL_FROM="Outrun <noreply@outrun.app>"

# AI provider (Growth Blueprint generation and future AI features).
# Required — without it, Blueprint generation fails with a friendly error.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Lead data provider (company search, docs/outrun/06).
# Get one from Google Cloud Console -> enable "Places API (New)".
# Required — without it, prospect search fails with a friendly error.
GOOGLE_PLACES_API_KEY=""

# Billing (Paddle, docs/outrun/14). Get these from paddle.com -> Developer Tools.
# PADDLE_API_KEY: Authentication -> API keys (server-side only).
# PADDLE_WEBHOOK_SECRET: Notifications -> add a webhook pointed at
#   <your-domain>/api/billing/webhook, subscribe to all subscription.* events,
#   then copy its signing secret.
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN: Authentication -> Client-side tokens.
# NEXT_PUBLIC_PADDLE_STARTER_PRICE_ID: the Price ID for the Starter plan
#   product you create in Paddle (Catalog -> Products).
# Required — without them, the Billing page shows Free/Starter but the
# upgrade button stays disabled with an explanatory note.
PADDLE_API_KEY=""
PADDLE_WEBHOOK_SECRET=""
NEXT_PUBLIC_PADDLE_ENVIRONMENT="sandbox"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=""
NEXT_PUBLIC_PADDLE_STARTER_PRICE_ID=""

# Observability (docs/outrun/15). Optional — without it, errors are still
# logged as structured JSON to the server console; setting this additionally
# forwards them to Sentry (or any Sentry-ingest-compatible service).
# Format: https://<public_key>@<host>/<project_id>
SENTRY_DSN=""

# Autonomous Growth Mode (docs/outrun/07). Shared secret checked by
# GET /api/cron/autonomous-send — without it, that endpoint refuses every
# request rather than running unauthenticated. See DEPLOYMENT.md for how
# to point a scheduler (Vercel Cron or the included GitHub Action) at it.
CRON_SECRET=""
