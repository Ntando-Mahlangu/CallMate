# Postgres connection string
DATABASE_URL="postgresql://outrun:outrun_dev_password@localhost:5432/outrun_dev"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Continue with Google button is hidden until these are set)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Outbound email (verification / password reset).
# Leave unset in development: emails are logged to the server console instead.
RESEND_API_KEY=""
EMAIL_FROM="Outrun <noreply@outrun.app>"
